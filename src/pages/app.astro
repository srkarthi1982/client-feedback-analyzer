---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvCard, AvInput, AvSelect, AvTextarea } from "@ansiversa/components";
---

<AppShell title="Client Feedback Analyzer" description="Group and review client insights.">
  <main class="feedback-workspace" x-data="$store.feedbackApp" x-init="init()">
    <section class="feedback-left">
      <AvCard className="feedback-card">
        <h2>Batch basics</h2>
        <div class="feedback-grid-two">
          <AvInput label="Batch / Project Name" x-model="draft.basics.projectName" @input="saveDraft()" placeholder="Q2 Product Feedback" />
          <AvInput label="Client / Company" x-model="draft.basics.clientName" @input="saveDraft()" placeholder="Northwind Logistics" />
          <AvInput label="Reviewer / Owner" x-model="draft.basics.owner" @input="saveDraft()" placeholder="A. Patel" />
          <AvInput label="Review period" x-model="draft.basics.reviewPeriod" @input="saveDraft()" placeholder="Jan–Mar 2026" />
        </div>
        <AvTextarea label="Overall notes" rows={3} x-model="draft.basics.overallNotes" @input="saveDraft()" placeholder="Context for this review batch." />
      </AvCard>

      <AvCard className="feedback-card">
        <div class="feedback-header-row">
          <h2>Feedback items</h2>
          <span class="feedback-muted" x-text="`${draft.feedbackItems.length} total`"></span>
        </div>

        <div class="feedback-form-grid">
          <AvTextarea label="Feedback text" rows={3} x-model="itemForm.text" placeholder="Share the core feedback from the client." />
          <AvInput label="Source" x-model="itemForm.source" placeholder="Call transcript, survey, email..." />
          <AvSelect label="Sentiment" x-model="itemForm.sentiment">
            <template x-for="option in sentimentOptions" :key="option">
              <option x-text="option"></option>
            </template>
          </AvSelect>
          <AvSelect label="Category" x-model="itemForm.category">
            <template x-for="option in categoryOptions" :key="option">
              <option x-text="option"></option>
            </template>
          </AvSelect>
          <AvSelect label="Priority" x-model="itemForm.priority">
            <template x-for="option in priorityOptions" :key="option">
              <option x-text="option"></option>
            </template>
          </AvSelect>
        </div>

        <div class="feedback-actions-row">
          <AvButton @click="upsertFeedbackItem()" x-text="editingItemId ? 'Update item' : 'Add item'"></AvButton>
          <AvButton variant="ghost" @click="resetItemForm()">Clear editor</AvButton>
        </div>

        <ul class="feedback-item-list" x-show="draft.feedbackItems.length > 0">
          <template x-for="item in draft.feedbackItems" :key="item.id">
            <li class="feedback-item">
              <div>
                <p class="feedback-item-text" x-text="item.text"></p>
                <p class="feedback-muted" x-text="`${item.source || 'Source not provided'} • ${item.sentiment} • ${item.category} • ${item.priority}`"></p>
              </div>
              <div class="feedback-item-actions">
                <AvButton size="sm" variant="outline" @click="editItem(item.id)">Edit</AvButton>
                <AvButton size="sm" variant="ghost" @click="deleteItem(item.id)">Delete</AvButton>
              </div>
            </li>
          </template>
        </ul>
        <p class="feedback-muted" x-show="draft.feedbackItems.length === 0">No feedback items yet. Add your first insight above.</p>
      </AvCard>

      <AvCard className="feedback-card">
        <h2>Filters and grouping</h2>
        <div class="feedback-grid-three">
          <AvSelect label="Sentiment" x-model="draft.filters.sentiment" @change="saveDraft()">
            <option>All</option>
            <template x-for="option in sentimentOptions" :key="option"><option x-text="option"></option></template>
          </AvSelect>
          <AvSelect label="Category" x-model="draft.filters.category" @change="saveDraft()">
            <option>All</option>
            <template x-for="option in categoryOptions" :key="option"><option x-text="option"></option></template>
          </AvSelect>
          <AvSelect label="Priority" x-model="draft.filters.priority" @change="saveDraft()">
            <option>All</option>
            <template x-for="option in priorityOptions" :key="option"><option x-text="option"></option></template>
          </AvSelect>
        </div>
      </AvCard>

      <AvCard className="feedback-card">
        <h2>Insight summary draft</h2>
        <AvTextarea label="Key strengths" rows={3} x-model="draft.summary.keyStrengths" @input="saveDraft()" placeholder="What is consistently working well?" />
        <AvTextarea label="Main concerns" rows={3} x-model="draft.summary.mainConcerns" @input="saveDraft()" placeholder="What issues are recurring?" />
        <AvTextarea label="Recommended actions" rows={3} x-model="draft.summary.recommendedActions" @input="saveDraft()" placeholder="What should happen next?" />
      </AvCard>

      <AvCard className="feedback-card">
        <div class="feedback-actions-row wrap">
          <AvButton variant="outline" @click="copyCurrentSummary()">Copy current summary</AvButton>
          <AvButton variant="outline" @click="copyFullReport()">Copy full feedback report</AvButton>
          <AvButton variant="ghost" @click="confirmResetWorkspace()">Reset / new review</AvButton>
        </div>
        <p class="feedback-muted" x-show="copyStatus" x-text="copyStatus"></p>

        <div class="feedback-reset-confirm" x-show="showResetConfirm">
          <p>Are you sure you want to clear this workspace?</p>
          <div class="feedback-actions-row">
            <AvButton variant="ghost" @click="showResetConfirm = false">Cancel</AvButton>
            <AvButton @click="resetWorkspace()">Confirm reset</AvButton>
          </div>
        </div>
      </AvCard>
    </section>

    <section class="feedback-right">
      <AvCard className="feedback-card feedback-preview">
        <h2>Live structured summary preview</h2>

        <h3 x-text="draft.basics.projectName || 'Untitled Review Batch'"></h3>
        <p class="feedback-muted" x-text="`Client: ${draft.basics.clientName || 'Not specified'} • Review period: ${draft.basics.reviewPeriod || 'Not specified'} • Owner: ${draft.basics.owner || 'Not specified'}`"></p>

        <div class="feedback-overview-grid" x-data="{sentimentCounts: counts()}">
          <div><strong x-text="draft.feedbackItems.length"></strong><span>Total items</span></div>
          <div><strong x-text="counts().Positive"></strong><span>Positive</span></div>
          <div><strong x-text="counts().Neutral"></strong><span>Neutral</span></div>
          <div><strong x-text="counts().Negative"></strong><span>Negative</span></div>
        </div>

        <article>
          <h4>Key strengths</h4>
          <p x-text="draft.summary.keyStrengths || 'No strengths drafted yet.'"></p>
        </article>

        <article>
          <h4>Main concerns</h4>
          <p x-text="draft.summary.mainConcerns || 'No concerns drafted yet.'"></p>
        </article>

        <article>
          <h4>Recommended actions</h4>
          <p x-text="draft.summary.recommendedActions || 'No recommended actions drafted yet.'"></p>
        </article>

        <article>
          <h4>Recent / filtered feedback items</h4>
          <ul class="feedback-preview-list">
            <template x-for="item in filteredItems().slice(0, 6)" :key="item.id">
              <li>
                <p x-text="item.text"></p>
                <p class="feedback-muted" x-text="`${item.source || 'Source not provided'} • ${item.sentiment} • ${item.category} • ${item.priority}`"></p>
              </li>
            </template>
          </ul>
          <p class="feedback-muted" x-show="filteredItems().length === 0">No feedback items match current filters.</p>
        </article>
      </AvCard>
    </section>
  </main>
</AppShell>

<style>
  .feedback-workspace {
    width: min(1280px, 100% - 2rem);
    margin: 1.5rem auto 2rem;
    display: grid;
    grid-template-columns: 1.25fr 0.9fr;
    gap: 1rem;
  }

  .feedback-left,
  .feedback-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .feedback-card { padding: 1rem; }
  .feedback-card h2 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.8rem; }
  .feedback-card h3 { font-size: 1.2rem; font-weight: 600; margin-bottom: 0.2rem; }
  .feedback-card h4 { margin-top: 0.8rem; margin-bottom: 0.4rem; font-weight: 600; }
  .feedback-grid-two { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; }
  .feedback-grid-three { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem; }
  .feedback-form-grid { display: grid; gap: 0.75rem; }
  .feedback-header-row,
  .feedback-actions-row { display: flex; justify-content: space-between; align-items: center; gap: 0.6rem; }
  .feedback-actions-row.wrap { flex-wrap: wrap; justify-content: flex-start; }
  .feedback-muted { font-size: 0.875rem; opacity: 0.75; }
  .feedback-item-list { margin-top: 0.8rem; display: grid; gap: 0.7rem; max-height: 18rem; overflow: auto; }
  .feedback-item { border: 1px solid rgba(148, 163, 184, 0.25); border-radius: 10px; padding: 0.75rem; display: flex; justify-content: space-between; gap: 0.75rem; }
  .feedback-item-text { margin-bottom: 0.25rem; }
  .feedback-item-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .feedback-preview { position: sticky; top: 1rem; }
  .feedback-overview-grid { margin-top: 0.85rem; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.5rem; }
  .feedback-overview-grid div { border: 1px solid rgba(148, 163, 184, 0.25); border-radius: 8px; padding: 0.5rem; text-align: center; display: flex; flex-direction: column; gap: 0.1rem; }
  .feedback-preview-list { display: grid; gap: 0.6rem; }
  .feedback-reset-confirm { margin-top: 0.8rem; padding-top: 0.8rem; border-top: 1px solid rgba(148, 163, 184, 0.25); display: grid; gap: 0.6rem; }

  @media (max-width: 960px) {
    .feedback-workspace { grid-template-columns: minmax(0, 1fr); }
    .feedback-preview { position: static; }
  }

  @media (max-width: 700px) {
    .feedback-grid-two,
    .feedback-grid-three,
    .feedback-overview-grid { grid-template-columns: minmax(0, 1fr); }
  }
</style>
