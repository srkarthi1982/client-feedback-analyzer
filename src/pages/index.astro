---
import AppShell from "../layouts/AppShell.astro";
import LandingPageStandard from "../components/landing/LandingPageStandard.astro";
import type { LandingPageContent } from "../lib/landing";

const landingContent: LandingPageContent = {
  categoryLabel: "Business Operations",
  appLabel: "Public local-only workspace",
  title: "Turn raw client feedback into a structured review set.",
  subtitle:
    "Collect feedback batches, categorize what matters, and prepare copy-ready summaries from one calm browser workspace without server setup.",
  heroBullets: [
    "Capture feedback items with sentiment, category, priority, and reviewer notes",
    "Filter the workspace and keep grouped counts visible while you refine the review set",
    "Copy either a concise summary or a fuller report from the current local draft state",
  ],
  primaryCta: {
    label: "Open Workspace",
    href: "/app",
  },
  secondaryCta: {
    label: "See Workflow",
    href: "#workflow",
    variant: "ghost",
  },
  heroNote: "Current V1 runs entirely in the browser and stores draft state in localStorage.",
  heroPanel: {
    eyebrow: "Review flow",
    title: "Collect → Organize → Copy",
    steps: [
      "1. Add feedback items into the current review batch",
      "2. Group by sentiment, category, and priority",
      "3. Copy a summary or full report for external use",
    ],
    meta: [
      { value: "Local", label: "Storage model" },
      { value: "Public", label: "Workspace access" },
    ],
  },
  heroStats: [
    { value: "Browser", label: "Runs locally" },
    { value: "Draft-safe", label: "Persists on refresh" },
    { value: "Copy-ready", label: "Summary output" },
  ],
  features: {
    title: "What V1 helps you do",
    lead:
      "The app is focused on shaping a review set cleanly, not on heavy automation or server-side reporting.",
    items: [
      {
        title: "Structured feedback capture",
        description:
          "Record feedback items with client context, reviewer notes, sentiment, category, and priority in one place.",
      },
      {
        title: "Instant grouped counts",
        description:
          "See how the batch is distributed by sentiment, category, and priority while you work.",
      },
      {
        title: "Filter before you summarize",
        description:
          "Narrow the visible review set so copied output reflects the exact slice you want to discuss.",
      },
      {
        title: "Edit and delete locally",
        description:
          "Refine the draft set directly in the browser without server-backed CRUD or user setup.",
      },
      {
        title: "Summary and full report copy",
        description:
          "Copy either a concise summary or a longer structured report from the current workspace state.",
      },
      {
        title: "Refresh-safe draft persistence",
        description:
          "Local draft state survives refresh in the same browser until you reset it intentionally.",
      },
    ],
  },
  pillars: {
    title: "Why this workspace feels stronger than a plain notes page",
    lead:
      "V1 is small on purpose, but it still gives feedback review a clearer structure than freeform drafting.",
    items: [
      {
        title: "Local-first clarity",
        description:
          "You can start using it immediately because the workflow is public and browser-local in current V1.",
      },
      {
        title: "Review-focused structure",
        description:
          "The app is built around feedback analysis fields instead of generic text blocks, which keeps batches readable.",
      },
      {
        title: "Calm output preparation",
        description:
          "Grouped counts and filtered views help you shape the final narrative before you copy anything out.",
      },
      {
        title: "No false back-end claims",
        description:
          "The current implementation stays honest: it does not imply server workflows, collaboration, or authenticated sharing.",
      },
    ],
  },
  workflow: {
    eyebrow: "How it works",
    title: "From raw comments to a usable review summary",
    lead:
      "The workflow is designed for one person cleaning up a feedback batch and exporting the current state.",
    steps: [
      {
        title: "Start a local feedback batch",
        description:
          "Open the public workspace and add each feedback item with the fields that matter for review.",
      },
      {
        title: "Organize the signal",
        description:
          "Edit, filter, and inspect grouped counts so strengths, concerns, and high-priority themes become clear.",
      },
      {
        title: "Copy the output you need",
        description:
          "Use the summary or full-report copy actions to move the current draft into an email, document, or meeting note.",
      },
    ],
  },
  showcase: {
    eyebrow: "Output shape",
    title: "Built for structured review output, not just raw note capture",
    description:
      "This landing page stays truthful to V1: the app helps you prepare a clear feedback review set in-browser and copy the result elsewhere.",
    bullets: [
      "Best for batch review, stakeholder prep, and structured recap drafting",
      "Useful when you need grouped signals before writing a final recommendation",
      "No DB, collaboration layer, or server-backed report sharing in current V1",
    ],
    calloutLabel: "V1 boundary",
    calloutValue: "Local-only draft workspace",
  },
  finalCta: {
    title: "Start organizing the current feedback batch",
    description:
      "Open the workspace, shape the review set, and leave with copy-ready output that reflects the visible draft state.",
    primaryCta: {
      label: "Open Workspace",
      href: "/app",
    },
    secondaryCta: {
      label: "Review Features",
      href: "#features",
      variant: "ghost",
    },
  },
};
---

<AppShell title="Client Feedback Analyzer – Ansiversa" description="Group and review client insights.">
  <LandingPageStandard content={landingContent} />
</AppShell>
