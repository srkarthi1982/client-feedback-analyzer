---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
---

<AppShell title="Client Feedback Analyzer – Ansiversa" description="Group and review client insights.">
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker"><span>Business Operations · Ansiversa Mini App</span></div>
        <h1 class="av-gradient-text">Client Feedback Analyzer</h1>
        <p>A premium workspace to collect, group, and summarize client feedback with clarity.</p>
      </div>
      <div class="av-cta-row"><AvButton href="/app">Open Workspace</AvButton></div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="narrow">
      <AvCard>
        <h2 class="av-section-title">What you can do in V1</h2>
        <ul class="space-y-2 text-slate-300 list-disc list-inside mt-3">
          <li>Capture feedback batches, context, and reviewer notes.</li>
          <li>Track feedback items by sentiment, category, and priority.</li>
          <li>Draft key strengths, concerns, and recommended actions.</li>
          <li>Copy a concise summary or a full structured report.</li>
        </ul>
      </AvCard>
    </AvContainer>
  </section>
</AppShell>
